# Default: let Git auto-detect text files and normalize to LF in the repo.
* text=auto eol=lf

# Files that MUST be LF inside the container regardless of host OS.
# MySQL silently ignores .cnf files with CRLF line endings, and some
# mysql init scripts choke on CRLF. Force LF for anything mounted
# into or copied into the Linux container.
docker/**         text eol=lf
*.sh              text eol=lf
*.cnf             text eol=lf
*.sql             text eol=lf
Dockerfile        text eol=lf
docker-compose.yml text eol=lf
.env              text eol=lf
.env.example      text eol=lf

# Known binary types — never touch these.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
